[
  {
    "id": 0,
    "text": "愛梨、"
  },
  {
    "id": 1,
    "text": "愛梨ちゃんがいなかったら今の雫もないし。"
  },
  {
    "id": 2,
    "text": "、ティアデ時代も愛梨ちゃん、"
  },
  {
    "id": 3,
    "text": "、"
  },
  {
    "id": 4,
    "text": "キュティー時代の愛梨ちゃんにいっぱい励ましてもらったんで、この2人の関係が見える。"
  },
  {
    "id": 5,
    "text": "そして遥。"
  },
  {
    "id": 6,
    "text": "特訓、すごい。"
  },
  {
    "id": 7,
    "text": "この、"
  },
  {
    "id": 8,
    "text": "、カエル、がびっくりし。"
  },
  {
    "id": 9,
    "text": "このなんか表情めっちゃ可愛く?"
  },
  {
    "id": 10,
    "text": "葉っぱに着地してる。"
  },
  {
    "id": 11,
    "text": "いいよ。"
  },
  {
    "id": 12,
    "text": "、遥ちゃんの衣装は赤ってよりちょっとオレンジが入ってんのもまた、"
  },
  {
    "id": 13,
    "text": "めっちゃ可愛いよ。"
  },
  {
    "id": 14,
    "text": "このちょっとした衣装の違いと、"
  },
  {
    "id": 15,
    "text": "すごい。"
  },
  {
    "id": 16,
    "text": "なんか初音幹も、めちゃくちゃ。"
  },
  {
    "id": 17,
    "text": "。"
  },
  {
    "id": 18,
    "text": "、"
  },
  {
    "id": 19,
    "text": "特訓前です。"
  },
  {
    "id": 20,
    "text": "これが、アイハザ本番の撮影スタジオか?"
  },
  {
    "id": 21,
    "text": "、背景の、カメラさんとか、後ろの非常口の、、"
  },
  {
    "id": 22,
    "text": "非常用灯の感じと、"
  },
  {
    "id": 23,
    "text": "、カメラの下に、右下にあるモニターとか、結構。"
  },
  {
    "id": 24,
    "text": "本当に、こんな感じなんだ。"
  },
  {
    "id": 25,
    "text": "スタジオ立ってカメラがある時の目線とか。"
  },
  {
    "id": 26,
    "text": "多分この遥、。"
  },
  {
    "id": 27,
    "text": "ドキドキって感じだ、本当本番に向かう前の、"
  },
  {
    "id": 28,
    "text": "この表情すごくいいよ。"
  },
  {
    "id": 29,
    "text": "、カメラ?"
  },
  {
    "id": 30,
    "text": "でも本当こんな感じな。"
  },
  {
    "id": 31,
    "text": "だから、いろんな角度からいろんな表情を、、常に撮ってくださっ、"
  },
  {
    "id": 32,
    "text": "カメラを切り替えて皆さんが、いつも見、"
  },
  {
    "id": 33,
    "text": "くれてる画面になるんだ、、こんな感じなんだ。"
  },
  {
    "id": 34,
    "text": "めちゃくちゃリアルだ。"
  },
  {
    "id": 35,
    "text": "、、、最後に芽衣ちゃんです。"
  },
  {
    "id": 36,
    "text": "芽衣、なんてエレガントなん。"
  },
  {
    "id": 37,
    "text": "この白、白のだっ、白の、この、すっごいお。"
  },
  {
    "id": 38,
    "text": "でも似合う。"
  },
  {
    "id": 39,
    "text": "さすが芽衣。"
  },
  {
    "id": 40,
    "text": "、やっぱ大人っぽいよ。"
  },
  {
    "id": 41,
    "text": "すっごい。"
  },
  {
    "id": 42,
    "text": "、お花持って、"
  },
  {
    "id": 43,
    "text": "めっちゃ可愛いよ。"
  },
  {
    "id": 44,
    "text": "この袖がちょっと広がってる感じと、すごい。"
  },
  {
    "id": 45,
    "text": "、って感じで、"
  },
  {
    "id": 46,
    "text": "見ていった、このグループ名、ちっちゃくなっちゃったって書きたかったんだ、"
  },
  {
    "id": 47,
    "text": "文字数制限でちっちゃくなっ、になっちゃっ。"
  },
  {
    "id": 48,
    "text": "そういう時あるよ。"
  },
  {
    "id": 49,
    "text": "どういう?"
  }
]