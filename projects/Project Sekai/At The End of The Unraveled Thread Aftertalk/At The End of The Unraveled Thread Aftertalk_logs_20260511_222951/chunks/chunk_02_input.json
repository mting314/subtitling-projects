[
  {
    "id": 0,
    "text": "、まぁまぁジャンプのメンバーありがとうと本当に言い。",
    "start_time": 776.78,
    "end_time": 779.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "もっと、深掘りした話はちょっとまた後に、お話ししたいと思い。",
    "start_time": 780.32,
    "end_time": 784.72,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "、、今日も1話だけみんなと、この場で一緒に見たいんだけどみんな何話が?",
    "start_time": 785.44,
    "end_time": 793.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "私は、、、本番アイハザの本番の、バチバチのバトルをね見たいんだ、",
    "start_time": 794.96,
    "end_time": 804.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "みんな?",
    "start_time": 804.88,
    "end_time": 807.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "7話とか8話。",
    "start_time": 807.0,
    "end_time": 808.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "そうなると皆さんどうですか?",
    "start_time": 809.56,
    "end_time": 813.02,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "、何だろう、、過去の話というか今までも、シアデイ時代の話ってちょろっとこう、",
    "start_time": 813.02,
    "end_time": 821.18,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "断片的に出てたところあったんですけど今回ガッツリ掘り下げ、",
    "start_time": 821.18,
    "end_time": 826.26,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "本当に具体的にこんなことがあったんだっていう感じなので、",
    "start_time": 826.26,
    "end_time": 831.42,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "まよけれどもやっぱ78が7が多いか。",
    "start_time": 831.42,
    "end_time": 836.48,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "、、7か?",
    "start_time": 840.48,
    "end_time": 842.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "7でいいです?",
    "start_time": 843.08,
    "end_time": 844.225,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "。",
    "start_time": 844.225,
    "end_time": 844.87,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "、皆さん7話を見ていきましょう。",
    "start_time": 845.44,
    "end_time": 849.04,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "。",
    "start_time": 849.04,
    "end_time": 849.64,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "なんかまたみんなと見ると",
    "start_time": 852.0,
    "end_time": 853.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "面白いよ。",
    "start_time": 855.28,
    "end_time": 856.64,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "。",
    "start_time": 858.09,
    "end_time": 858.59,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
