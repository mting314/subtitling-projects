[
  {
    "id": 0,
    "text": "、衣装可愛いっ。",
    "start_time": 3528.08,
    "end_time": 3529.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "、結構シンプル、、そうそう、で、私、、コメント、、",
    "start_time": 3530.96,
    "end_time": 3537.84,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "教えてもらったんだけど、、雫の衣装とか、見てて思った。",
    "start_time": 3537.84,
    "end_time": 3543.38,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "なんか最初このカードのイラスト見た時、、妖精さんなっちゃった、",
    "start_time": 3543.38,
    "end_time": 3548.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "、可愛いねって思っ、ふふって見てたんだけど、これもしかして今回の、",
    "start_time": 3548.2,
    "end_time": 3554.14,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "親指姫じゃないって教えてくれた人がい、、私、",
    "start_time": 3554.14,
    "end_time": 3558.42,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "親指姫、もちろんタイトルは知ってたけどちゃんと見たことなかったの。",
    "start_time": 3558.42,
    "end_time": 3564.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "、どんなお話だったっけって調べたらさ、すごいかいつまむ、こういうねお花で生まれたちっちゃい女の子が親指姫って名付けてもらって、",
    "start_time": 3564.0,
    "end_time": 3576.66,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "なんか連れ去られちゃったりと、、身の危険を感じて、",
    "start_time": 3576.66,
    "end_time": 3580.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "いろんなことがあっ、本当に大変なことがあったんだ。",
    "start_time": 3580.88,
    "end_time": 3583.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "だ、最後の最後にはツベ、ツベ?",
    "start_time": 3583.6,
    "end_time": 3586.9,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "ツバメさんに助けてもらって、自由になってハッピーエンドっていうお話なんだっ。",
    "start_time": 3586.9,
    "end_time": 3593.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "、さ",
    "start_time": 3594.39,
    "end_time": 3594.89,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "ツバメじゃ、この?",
    "start_time": 3597.76,
    "end_time": 3599.12,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "黒と白。",
    "start_time": 3599.64,
    "end_time": 3600.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "穂乃果ちゃんも愛莉ちゃん、遥ちゃんも言われてみたらツバメっぽいんだよ。",
    "start_time": 3602.68,
    "end_time": 3608.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "なんかこの、胸元の黄色とか、くちばしっぽいしこれ気づいた人すごいと思っ、",
    "start_time": 3609.6,
    "end_time": 3615.82,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "、教えてくれ。",
    "start_time": 3615.82,
    "end_time": 3617.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "本当に、こうやっ、なんか1、なるほどなっていうのがある、",
    "start_time": 3617.92,
    "end_time": 3621.84,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 19,
    "text": "見方が変わる、こうやってカエルさんもいるし、カエルさんも登場するんだ、",
    "start_time": 3621.84,
    "end_time": 3625.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 20,
    "text": "親指姫。",
    "start_time": 3625.88,
    "end_time": 3626.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 21,
    "text": "なるほどなって思った、面白いよ。",
    "start_time": 3627.4,
    "end_time": 3629.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 22,
    "text": "、その親指姫のストーリー、なん、なんか諦めなければ",
    "start_time": 3631.12,
    "end_time": 3635.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 23,
    "text": "夢は叶うじゃない、自由になれるっていう感じがさあっ、まさにこのストーリーじゃんって思っ、",
    "start_time": 3637.4,
    "end_time": 3644.56,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "ツバメさんに助けてもらっ、雫は羽ばたけるみたいな。",
    "start_time": 3644.56,
    "end_time": 3648.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "エムエムです、本当。",
    "start_time": 3650.08,
    "end_time": 3651.56,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "、そんな感じなだ、、本当教えてくれ。",
    "start_time": 3652.96,
    "end_time": 3655.84,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "。",
    "start_time": 3656.88,
    "end_time": 3657.84,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 28,
    "text": "ということ、このほどかれた糸のその先にのストーリーとか、",
    "start_time": 3659.16,
    "end_time": 3663.78,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 29,
    "text": "色々相まってイラストもとても素敵でござし。",
    "start_time": 3663.78,
    "end_time": 3667.0,
    "speaker": "",
    "role": null,
    "corner": null
  }
]