    "start_time": 3384.04,
    "end_time": 3385.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "すごい。",
    "start_time": 3385.32,
    "end_time": 3386.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "このさ、カエルさんがびっくりし。",
    "start_time": 3386.32,
    "end_time": 3390.84,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "このなんか表情めっちゃ可愛く?",
    "start_time": 3390.84,
    "end_time": 3393.56,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "葉っぱに着地してる。",
    "start_time": 3394.24,
    "end_time": 3395.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
