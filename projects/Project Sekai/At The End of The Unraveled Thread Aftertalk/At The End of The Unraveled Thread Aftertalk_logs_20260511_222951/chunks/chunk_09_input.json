[
  {
    "id": 0,
    "text": "ありがとうござし。",
    "start_time": 3667.0,
    "end_time": 3668.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "。",
    "start_time": 3670.04,
    "end_time": 3670.72,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "、、私、、有咲、有咲ちゃんについて、すっごい喋りたいことがあって",
    "start_time": 3671.56,
    "end_time": 3678.44,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "この今回のストーリー、?",
    "start_time": 3680.12,
    "end_time": 3683.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "構造、やっぱり雫と、バチバチにぶつかりあっちゃって、アチアでのメンバーたちと、",
    "start_time": 3683.92,
    "end_time": 3690.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "だから見え方的に結構有咲ちゃんと、元シアターの子達とかが、",
    "start_time": 3690.4,
    "end_time": 3695.94,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "、ビラン側じゃない、くっ、、この子達はって思う場面も結構あったと思う。",
    "start_time": 3695.94,
    "end_time": 3701.48,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "、なんだろうね芽衣ちゃんも言ってた、、みんな本気でアイドルして、",
    "start_time": 3703.0,
    "end_time": 3710.06,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "本気でその雫がなった、センターっていうポジションになりたくてなりたく、",
    "start_time": 3710.06,
    "end_time": 3716.12,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "すっごい努力してきてる子達だ、だから、ああやって真剣に嫉妬もする、",
    "start_time": 3716.12,
    "end_time": 3721.82,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "努力もするしっていうのであの",
    "start_time": 3721.82,
    "end_time": 3726.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "、結構バチバチだったけど有咲ちゃんって、すっごい裏表のない子だなって私思っ、",
    "start_time": 3727.8,
    "end_time": 3734.72,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "っていうのも雫がそうね",
    "start_time": 3734.72,
    "end_time": 3738.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "有咲ちゃん達、そのシアターのメンバーと顔合わせをした瞬間に、",
    "start_time": 3740.48,
    "end_time": 3748.26,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "有咲ちゃんは、なんかこう私も本気で行く、あんたも本気で来、",
    "start_time": 3748.26,
    "end_time": 3752.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "みたい。",
    "start_time": 3752.76,
    "end_time": 3753.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "なんかそういう感じ、すっごい、言葉にして伝えてくれるんだよ。",
    "start_time": 3754.56,
    "end_time": 3759.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "、、。",
    "start_time": 3760.84,
    "end_time": 3761.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "だ、なんかそういう裏表のない、常に本気で全力で向き合ってくれる感じが私はすっごくかっこいいなって思っ。",
    "start_time": 3761.88,
    "end_time": 3770.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 19,
    "text": "。",
    "start_time": 3771.88,
    "end_time": 3772.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 20,
    "text": "思った。",
    "start_time": 3774.92,
    "end_time": 3775.5,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 21,
    "text": "、ただね、、その",
    "start_time": 3775.5,
    "end_time": 3779.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 22,
    "text": "なん、、",
    "start_time": 3780.76,
    "end_time": 3781.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 23,
    "text": "衣装を、隠してしまったりと、なんかそういうことがあって",
    "start_time": 3782.96,
    "end_time": 3787.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "やり方は良くなかったよねっていうのはもちろんあって。",
    "start_time": 3789.84,
    "end_time": 3796.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "だから",
    "start_time": 3796.68,
    "end_time": 3797.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "、センターになりたいからっ、そういう感情を持つのは全然悪いことじゃない、",
    "start_time": 3799.92,
    "end_time": 3806.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "本気でやってるから、そういうねくっそって気持ちとかが生まれるんだろうなっていうのは私もすごく理解できてだから反面教師にしないとっ、",
    "start_time": 3806.08,
    "end_time": 3815.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 28,
    "text": "これは、人事じゃないって私もすごく思っ。",
    "start_time": 3815.68,
    "end_time": 3818.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 29,
    "text": "、そういう嫉妬とかの気持ちの向け方と、矛先を1本間違えたら本当に良くないことが起こっちゃう、",
    "start_time": 3818.72,
    "end_time": 3826.62,
    "speaker": "",
    "role": null,
    "corner": null
  }
]