[
  {
    "id": 0,
    "text": "ちゃんと自分の意思があっ、、ありがとうってちゃんと面と向かって言える強、",
    "start_time": 1706.36,
    "end_time": 1711.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "が本当に際立ったシーンだったなって今すごく思っ、、こうやって言葉にし、",
    "start_time": 1711.8,
    "end_time": 1720.78,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "しかもも本番中に、撮影の本番中に勇気を持っ、こうやってはっきり自分の思いも伝えたかったことも全部言葉にして言えるいっ雫は本当に世界一かっこて。",
    "start_time": 1720.78,
    "end_time": 1736.02,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "本当に、抱きしめてあげ。",
    "start_time": 1736.02,
    "end_time": 1738.06,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "もう私の心の中では抱きしめてい。",
    "start_time": 1738.06,
    "end_time": 1740.56,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "本当に最高だ。",
    "start_time": 1740.56,
    "end_time": 1742.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "で、雫が怒らない、愛梨ちゃんが、シャーってやってくれるじゃ?",
    "start_time": 1742.68,
    "end_time": 1747.12,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "この構図も、すっごいいい、",
    "start_time": 1747.88,
    "end_time": 1751.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "なんかまたこのアイドルの、バチバチな感じと、、その愛梨ちゃんの、",
    "start_time": 1752.52,
    "end_time": 1757.0,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "私も思うところがあったりするの、、そんな話もちょっと後半で、",
    "start_time": 1757.0,
    "end_time": 1761.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "したいと思うん、ありがとうございまし。",
    "start_time": 1761.32,
    "end_time": 2913.38,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "なんかいい、こうやってみんなで見れるのも。",
    "start_time": 2913.38,
    "end_time": 2915.48,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "、",
    "start_time": 2916.56,
    "end_time": 2918.12,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "心がギュンギュンし。",
    "start_time": 2919.08,
    "end_time": 2920.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "。",
    "start_time": 2921.17,
    "end_time": 2921.67,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "どうでした?",
    "start_time": 2922.32,
    "end_time": 2923.18,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "私、私たちは今回新曲でござい。",
    "start_time": 2923.18,
    "end_time": 2927.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "前回のワンダショーチャンネルでちょろっと、ご紹介させてもらった新曲なんだけどなんかすごいかっこよかったよ。",
    "start_time": 2927.08,
    "end_time": 2937.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "なん、モモジャンも今までいろんな楽曲を歌わせていただいて、",
    "start_time": 2938.24,
    "end_time": 2944.62,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 19,
    "text": "その度にいろんな一面だっ、いろんな表情だったりを見せられていたのかなって私も感じてたんだ、",
    "start_time": 2944.62,
    "end_time": 2954.48,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 20,
    "text": "またこう違うかっこよさが、",
    "start_time": 2954.48,
    "end_time": 2958.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 21,
    "text": "見られて、今回はこう、アフターライブだからこうライブとし、",
    "start_time": 2958.92,
    "end_time": 2964.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 22,
    "text": "、衣装も、相まってすっごいかっこよかっ。",
    "start_time": 2964.36,
    "end_time": 2968.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 23,
    "text": "、Bメロに入る時の1回安定し、、廉君がさセンターに来るところのあのライトの感じとか私すっごい。",
    "start_time": 2969.44,
    "end_time": 2979.06,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "本当に良かったし、、、高音が、すっごい、、レコーディングも、",
    "start_time": 2979.06,
    "end_time": 2986.44,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "楽しくって、今回、レコーディングにするにあたってこう、テーマじゃないけどやっぱり今回のシナリオで雫がまた第1段階、",
    "start_time": 2986.44,
    "end_time": 3001.46,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "踏み込んだところに行くというのもあって私としても雫に羽が入るじゃない、",
    "start_time": 3001.46,
    "end_time": 3009.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "こう覚醒する感じがやっぱりこの曲にはそんなパワーがあるなって感じたの、",
    "start_time": 3009.76,
    "end_time": 3015.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 28,
    "text": "資料いただいた時にね本当にいろんな思いが歌詞にも詰まってた、",
    "start_time": 3015.4,
    "end_time": 3021.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 29,
    "text": "だからやっぱりそれをね",
    "start_time": 3021.4,
    "end_time": 3022.92,
    "speaker": "",
    "role": null,
    "corner": null
  }
]