[
  {
    "id": 0,
    "text": "メタモリボンの歌詞にも糸って入ってたり、結構キーワードなところがあったりしてなんかいいよ。",
    "start_time": 4124.56,
    "end_time": 4131.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "こういうちょっとしたつながりとかが私はすごい。",
    "start_time": 4131.76,
    "end_time": 4135.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "。",
    "start_time": 4138.27,
    "end_time": 4138.77,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "、みんないろんな考えとか意見あると思うからもうそういうの本当ハッシュタグつけてめちゃくちゃ呟いて結構ね生々しいところだから本当なん、",
    "start_time": 4139.96,
    "end_time": 4152.96,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "人によって感情移入するキャラクターとかも全然違うと思う、",
    "start_time": 4152.96,
    "end_time": 4157.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "いろんな思いがあって当たり前のことだからもうそういうところもねみんなで共有して。",
    "start_time": 4157.08,
    "end_time": 4163.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "、本当面白いシナリオでし。",
    "start_time": 4163.92,
    "end_time": 4166.04,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "、ということで",
    "start_time": 4167.28,
    "end_time": 4168.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "なんかすごい真面目じゃ、私。",
    "start_time": 4170.24,
    "end_time": 4172.215,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "。",
    "start_time": 4172.215,
    "end_time": 4172.77,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "なんかびっくりしちゃっ、自分。",
    "start_time": 4173.52,
    "end_time": 4175.32,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "、ちょっと、今日は1人だしなんかこうシナリオもシナリオだから結構言いたいことを私もちゃんと言おうと思って考えてき。",
    "start_time": 4175.32,
    "end_time": 4183.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "こういう時もあるんです。",
    "start_time": 4183.6,
    "end_time": 4184.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "なんか結構、私がワンダちょチャンネルとかで、MCをやらせていただくこととかあってだから?",
    "start_time": 4184.92,
    "end_time": 4193.16,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "最初に私が1人映った時、、ちょっと不安かもって多分思った瞬間あると思う、",
    "start_time": 4193.16,
    "end_time": 4198.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "みんな。",
    "start_time": 4198.36,
    "end_time": 4198.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "だけどこういう風に真面目に喋る時もあり。",
    "start_time": 4199.52,
    "end_time": 4204.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "、よろしくお願いし。",
    "start_time": 4205.4,
    "end_time": 4207.28,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "ありがとうござい。",
    "start_time": 4207.28,
    "end_time": 4208.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 19,
    "text": "、ということで短い間でしたけれども短い間でしたけれど、",
    "start_time": 4209.2,
    "end_time": 4213.72,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 20,
    "text": "短い時間でしたけれど、プロセカアフタートークほどかれた糸のその先に編は以上で終了となり。",
    "start_time": 4213.72,
    "end_time": 4221.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 21,
    "text": "配信ご覧の皆さんありがとうござい。",
    "start_time": 4222.44,
    "end_time": 4224.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 22,
    "text": "コメントも、すごいやってくれて、ちゃんと見てました。",
    "start_time": 4224.52,
    "end_time": 4228.56,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 23,
    "text": "ちょっと、全部拾うことはできなかったん、申し訳なかったです。",
    "start_time": 4228.56,
    "end_time": 4232.755,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "。",
    "start_time": 4232.755,
    "end_time": 4233.37,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "またこうやって、みんなと一緒にライブも、同じ部屋に入れたりとかさ今も、",
    "start_time": 4233.88,
    "end_time": 4240.36,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "生配信でリアルタイムで見てくれてる人と一緒につながれたりとかまたこう1人で見てる時と違う良さがあるなって、",
    "start_time": 4240.36,
    "end_time": 4249.16,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "思いまし。",
    "start_time": 4249.16,
    "end_time": 4250.24,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 28,
    "text": "みんなでもどうでしたか?",
    "start_time": 4250.24,
    "end_time": 4252.48,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 29,
    "text": "楽しかっ?",
    "start_time": 4252.48,
    "end_time": 4253.28,
    "speaker": "",
    "role": null,
    "corner": null
  }
]