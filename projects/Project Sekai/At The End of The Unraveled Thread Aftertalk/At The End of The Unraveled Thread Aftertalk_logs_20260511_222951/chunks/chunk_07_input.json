[
  {
    "id": 0,
    "text": "このちょっとした衣装の違いとか",
    "start_time": 3408.0,
    "end_time": 3410.16,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 1,
    "text": "すごい。",
    "start_time": 3411.76,
    "end_time": 3412.74,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 2,
    "text": "なんか初の花も、めちゃくちゃ。",
    "start_time": 3412.74,
    "end_time": 3414.68,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 3,
    "text": "。",
    "start_time": 3416.53,
    "end_time": 3417.03,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 4,
    "text": "そして",
    "start_time": 3420.93,
    "end_time": 3421.43,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 5,
    "text": "特訓前です。",
    "start_time": 3423.76,
    "end_time": 3424.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 6,
    "text": "これがねアイハザー本番の撮影スタジオか?",
    "start_time": 3425.52,
    "end_time": 3429.96,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 7,
    "text": "この背景の、カメラさんとか、後ろの非常口の、、",
    "start_time": 3429.96,
    "end_time": 3434.88,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 8,
    "text": "非常灯の感じとか、カメラの下に、右下にあるモニターとか、",
    "start_time": 3434.88,
    "end_time": 3440.42,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 9,
    "text": "結構。",
    "start_time": 3440.42,
    "end_time": 3441.6,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 10,
    "text": "本当に、こんな感じなんだ、スタジオ立ってカメラがある時の目線とか。",
    "start_time": 3441.6,
    "end_time": 3447.28,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 11,
    "text": "多分この遥ちゃんは",
    "start_time": 3448.84,
    "end_time": 3450.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 12,
    "text": "ドキドキって感じだ、本当本番に向かう前のさこの表情すごくいいよ。",
    "start_time": 3451.84,
    "end_time": 3459.28,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 13,
    "text": "、カメラ?",
    "start_time": 3459.88,
    "end_time": 3461.5,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 14,
    "text": "でも本当こんな感じな。",
    "start_time": 3461.5,
    "end_time": 3462.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 15,
    "text": "だから、いろんな角度からいろんな表情を、こう常に撮ってくださっ、",
    "start_time": 3463.76,
    "end_time": 3468.04,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 16,
    "text": "カメラを切り替え、皆さんが、いつも見てくれてる画面になるんだけど、",
    "start_time": 3468.04,
    "end_time": 3475.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 17,
    "text": "こんな感じなだ。",
    "start_time": 3475.08,
    "end_time": 3475.92,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 18,
    "text": "めちゃくちゃリアルだ。",
    "start_time": 3475.92,
    "end_time": 3477.04,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 19,
    "text": "、そして、最後に芽衣ちゃんです。",
    "start_time": 3479.0,
    "end_time": 3482.08,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 20,
    "text": "芽衣、なんてエレガントなん。",
    "start_time": 3483.12,
    "end_time": 3485.52,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 21,
    "text": "この白、白のだっ、白の、この、すっごいお。",
    "start_time": 3486.84,
    "end_time": 3492.94,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 22,
    "text": "でも似合う、さすが芽衣。",
    "start_time": 3492.94,
    "end_time": 3495.2,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 23,
    "text": "、やっぱ大人っぽいよ、すっごい。",
    "start_time": 3499.72,
    "end_time": 3502.82,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 24,
    "text": "、お花持って。",
    "start_time": 3502.82,
    "end_time": 3504.16,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 25,
    "text": "めっちゃ可愛いよ、この袖がちょっと広がってる感じとかすごい。",
    "start_time": 3505.72,
    "end_time": 3509.76,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 26,
    "text": "、って感じで一通り見ていった、このグループ名、ちっちゃくなっちゃったって書きたかっただ、",
    "start_time": 3512.04,
    "end_time": 3519.4,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 27,
    "text": "文字数制限でちっちゃくなっ、になっちゃっ。",
    "start_time": 3519.4,
    "end_time": 3521.96,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 28,
    "text": "そういう時あるよ。",
    "start_time": 3522.92,
    "end_time": 3523.8,
    "speaker": "",
    "role": null,
    "corner": null
  },
  {
    "id": 29,
    "text": "どういう?",
    "start_time": 3525.4,
    "end_time": 3526.16,
    "speaker": "",
    "role": null,
    "corner": null
  }
]