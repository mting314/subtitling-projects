[
  {
    "id": 0,
    "text": "。"
  },
  {
    "id": 1,
    "text": "、ということ、穂波のこちらが特訓後でございまし。"
  },
  {
    "id": 2,
    "text": "しかもちゃんと缶、リンゴなんだ。"
  },
  {
    "id": 3,
    "text": "。"
  },
  {
    "id": 4,
    "text": "いいよ。"
  },
  {
    "id": 5,
    "text": "、、続いては。"
  },
  {
    "id": 6,
    "text": "いちかの特訓。"
  },
  {
    "id": 7,
    "text": "これ7話でありました。"
  },
  {
    "id": 8,
    "text": "あのあんまり気にしなくていい、みたいな感じで、いちか言ってくれてました。"
  },
  {
    "id": 9,
    "text": "。"
  },
  {
    "id": 10,
    "text": "では続いてこれが特訓。"
  },
  {
    "id": 11,
    "text": "。"
  },
  {
    "id": 12,
    "text": "もう語彙力なくなるです。"
  },
  {
    "id": 13,
    "text": "よ、良すぎる。"
  },
  {
    "id": 14,
    "text": "いいしか言わなくこれ、、いちかの時は全体がこの、見えてる感じもまたいいですよ。"
  },
  {
    "id": 15,
    "text": "しかもこのギターを背負いながらこの三角座りしてるっていうのがまたいいよ。"
  },
  {
    "id": 16,
    "text": "なんか三角座、、三角座りって言いますよ。"
  },
  {
    "id": 17,
    "text": "座りって言うの。"
  },
  {
    "id": 18,
    "text": "。"
  },
  {
    "id": 19,
    "text": "、地域のものが出てしまいまし。"
  },
  {
    "id": 20,
    "text": "三角座りって関西?"
  },
  {
    "id": 21,
    "text": "言う。"
  },
  {
    "id": 22,
    "text": "聞いたことないです?"
  },
  {
    "id": 23,
    "text": "、ないです?"
  },
  {
    "id": 24,
    "text": "、?"
  },
  {
    "id": 25,
    "text": "ないです?"
  },
  {
    "id": 26,
    "text": "。"
  },
  {
    "id": 27,
    "text": "、?"
  },
  {
    "id": 28,
    "text": "ごめん、座り。"
  },
  {
    "id": 29,
    "text": "。"
  },
  {
    "id": 30,
    "text": "。"
  },
  {
    "id": 31,
    "text": "方言なのか?"
  },
  {
    "id": 32,
    "text": "失礼いたしまし。"
  },
  {
    "id": 33,
    "text": "座りしてるのってなんか学生感ありませ?"
  },
  {
    "id": 34,
    "text": "大人になってからあんましないですよ、体育座。"
  },
  {
    "id": 35,
    "text": "撮影の時にしかし、。"
  },
  {
    "id": 36,
    "text": "ここにちょこんと座って下さいって言われた時に体育座りするけど。"
  },
  {
    "id": 37,
    "text": "体育座りは、言う、三角座りは関西限定って言われて。"
  },
  {
    "id": 38,
    "text": "すみませんでし。"
  },
  {
    "id": 39,
    "text": "失礼いたしまし。"
  },
  {
    "id": 40,
    "text": "、なんか学生感あって個人的にはすごい好きです。"
  },
  {
    "id": 41,
    "text": "あと看板が結構楽器が。"
  },
  {
    "id": 42,
    "text": "もうなんか"
  },
  {
    "id": 43,
    "text": "すごい多く?"
  },
  {
    "id": 44,
    "text": "ギターもあっ、ベースもある、アコギも見えたりとかしてるし。"
  },
  {
    "id": 45,
    "text": "ドラムも若干見え。"
  },
  {
    "id": 46,
    "text": "、めっちゃ、。"
  },
  {
    "id": 47,
    "text": "。"
  },
  {
    "id": 48,
    "text": "、いちかでございまし。"
  },
  {
    "id": 49,
    "text": "次は鈴。"
  },
  {
    "id": 50,
    "text": "、特訓前の鈴。"
  },
  {
    "id": 51,
    "text": "もうルンルンでパーティーです。"
  },
  {
    "id": 52,
    "text": "鈴よ。"
  },
  {
    "id": 53,
    "text": "Leonid鈴ちゃんっていいよ。"
  },
  {
    "id": 54,
    "text": "このギャルみ溢れてる、本当好きなんだよ。"
  },
  {
    "id": 55,
    "text": "。"
  },
  {
    "id": 56,
    "text": "しかもこの首につけてるこの輪っかのやつって絶対作りましたよ、"
  },
  {
    "id": 57,
    "text": "学生の。"
  },
  {
    "id": 58,
    "text": "パーティーすると言ったらなんか壁とかにこうやってつけ。"
  },
  {
    "id": 59,
    "text": "。"
  },
  {
    "id": 60,
    "text": "しかもルーズソックスなのか?"
  },
  {
    "id": 61,
    "text": "。 っていうのがまたいいよ。"
  },
  {
    "id": 62,
    "text": "ギャル感があってよ。"
  },
  {
    "id": 63,
    "text": "、間違え。"
  },
  {
    "id": 64,
    "text": "特訓、。"
  },
  {
    "id": 65,
    "text": "。"
  },
  {
    "id": 66,
    "text": "すごく。"
  },
  {
    "id": 67,
    "text": "、このね鈴ちゃんの、何て言う?"
  },
  {
    "id": 68,
    "text": "魅力が詰まってるよ。"
  },
  {
    "id": 69,
    "text": "しかも中がノースリーブっていうのもいいよ。"
  },
  {
    "id": 70,
    "text": "しかもこの、、ここ何て言うんです?"
  },
  {
    "id": 71,
    "text": "道路の。"
  },
  {
    "id": 72,
    "text": "ここを歩いてるのもいいよ。"
  },
  {
    "id": 73,
    "text": "鈴ちゃんっぽいよ。"
  },
  {
    "id": 74,
    "text": "楽器振り回しちゃっダメだよって言いたくなっ。"
  },
  {
    "id": 75,
    "text": "怪我しないでねって言いたくなっ。"
  },
  {
    "id": 76,
    "text": "やっぱルーズソックスって可愛いよ。"
  },
  {
    "id": 77,
    "text": "流行りって1周するもんですよ。"
  },
  {
    "id": 78,
    "text": "本当に。"
  },
  {
    "id": 79,
    "text": "しかもこのリボンもまた可愛いよ。"
  }
]