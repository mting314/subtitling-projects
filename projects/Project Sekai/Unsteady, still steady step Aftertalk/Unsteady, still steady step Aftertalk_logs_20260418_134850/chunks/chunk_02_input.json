[
  {
    "id": 0,
    "text": "。"
  },
  {
    "id": 1,
    "text": "実は"
  },
  {
    "id": 2,
    "text": "ファンフェスタへの書き下ろし依頼が取り下げになりまし。"
  },
  {
    "id": 3,
    "text": "?"
  },
  {
    "id": 4,
    "text": "、、身構えないで。"
  },
  {
    "id": 5,
    "text": "こちら側に何か落ち度があったわけではありませ。"
  },
  {
    "id": 6,
    "text": "さっき担当者から連絡があったん。"
  },
  {
    "id": 7,
    "text": "体調不良だったクリエイターから連絡があったよう。"
  },
  {
    "id": 8,
    "text": "、"
  },
  {
    "id": 9,
    "text": "それってもともと書き下ろしを担当されてたって?"
  },
  {
    "id": 10,
    "text": "。"
  },
  {
    "id": 11,
    "text": "それで当初の予定通りに3曲とも間に合いそうだということで先方はひら謝りしてました。"
  },
  {
    "id": 12,
    "text": "電話の向こうで土下でもするんじゃないかってくらいの勢い。"
  },
  {
    "id": 13,
    "text": "、"
  },
  {
    "id": 14,
    "text": "そうだったんです。"
  },
  {
    "id": 15,
    "text": "でも元気になられて良かった。"
  },
  {
    "id": 16,
    "text": "お話がなくなったこと自体は少し残念です。"
  },
  {
    "id": 17,
    "text": "そうです。"
  },
  {
    "id": 18,
    "text": "ただ実は新たに依頼が来まし。"
  },
  {
    "id": 19,
    "text": "新たな?"
  },
  {
    "id": 20,
    "text": "担当者から次のファンフェスタでは是非フレッシュ枠でLeonidに書き下ろしをお願いしたいと言われているん。"
  },
  {
    "id": 21,
    "text": "今回のお詫びも兼ね。"
  },
  {
    "id": 22,
    "text": "?"
  },
  {
    "id": 23,
    "text": "少し期間は空きますが前向きに検討してはどうかと考えてい。"
  },
  {
    "id": 24,
    "text": "先の予定なのでスケジュールも問題ないでしょうし。"
  },
  {
    "id": 25,
    "text": "分かりまし。"
  },
  {
    "id": 26,
    "text": "その件に関しては改めてみんなに相談してみようと思い。"
  },
  {
    "id": 27,
    "text": "お願いし。"
  },
  {
    "id": 28,
    "text": "急ぐ話ではないのでゆっくり決めていただいて問題ありませ。"
  },
  {
    "id": 29,
    "text": "しかし結果的に色々とかき回すことになってしまって本当に申し訳ありませんでし。"
  },
  {
    "id": 30,
    "text": "本当リアルだよ。"
  },
  {
    "id": 31,
    "text": "。"
  },
  {
    "id": 32,
    "text": "仕方のないことだと思います。"
  },
  {
    "id": 33,
    "text": "それにお話を受ける前に分かって良かった。"
  },
  {
    "id": 34,
    "text": "そう言ってもらえると救われます。"
  },
  {
    "id": 35,
    "text": "今後は新曲づくりも含めワンマンに集中できるように全力でバックアップしていきますのでよろしくお願いし。"
  },
  {
    "id": 36,
    "text": "よろしくお願いし。"
  },
  {
    "id": 37,
    "text": "良かっ。"
  },
  {
    "id": 38,
    "text": "私今"
  },
  {
    "id": 39,
    "text": "それではメンバーの皆さんへの連絡はお任せします。"
  },
  {
    "id": 40,
    "text": "俺はワンマンのスタッフに連絡しておき。"
  },
  {
    "id": 41,
    "text": "新曲をやるセットリストで進めたい。"
  },
  {
    "id": 42,
    "text": "、"
  },
  {
    "id": 43,
    "text": "。"
  },
  {
    "id": 44,
    "text": "伝えておき。"
  },
  {
    "id": 45,
    "text": "よろしくお願いし。"
  },
  {
    "id": 46,
    "text": "それでは失礼し。"
  },
  {
    "id": 47,
    "text": "私"
  },
  {
    "id": 48,
    "text": "私今ほっとし。"
  },
  {
    "id": 49,
    "text": "。"
  },
  {
    "id": 50,
    "text": "そう。"
  },
  {
    "id": 51,
    "text": "私安心したん。"
  },
  {
    "id": 52,
    "text": "ちゃんと自分の考えを決めなきゃって思ってたのにどっちかを選ばなきゃって思ってたのにそれをしなくて良くなって"
  },
  {
    "id": 53,
    "text": "安心したん。"
  },
  {
    "id": 54,
    "text": "安心し。"
  },
  {
    "id": 55,
    "text": "えらいで"
  },
  {
    "id": 56,
    "text": "すごいえらい。"
  },
  {
    "id": 57,
    "text": "ほな。"
  },
  {
    "id": 58,
    "text": "ダメ。"
  },
  {
    "id": 59,
    "text": "今回はたまたま決めなくて済んだけどこの先何かを選ばなきゃいけない時はきっと。"
  },
  {
    "id": 60,
    "text": "。"
  },
  {
    "id": 61,
    "text": "正解がない選択を決断しないといけない時。"
  },
  {
    "id": 62,
    "text": "だから"
  },
  {
    "id": 63,
    "text": "決められるようにならなく。"
  },
  {
    "id": 64,
    "text": "。"
  },
  {
    "id": 65,
    "text": "みんなを導けるよう。"
  },
  {
    "id": 66,
    "text": "自分導けてる。"
  },
  {
    "id": 67,
    "text": "Leonidのリーダーとし。"
  },
  {
    "id": 68,
    "text": "。"
  },
  {
    "id": 69,
    "text": "。"
  },
  {
    "id": 70,
    "text": "ということで8話でございまし。"
  },
  {
    "id": 71,
    "text": "まあ個人的に何て言うんです、その気になったシーンという、"
  },
  {
    "id": 72,
    "text": "印象に残ったという部分ではやっぱさっきの、、穂波ちゃんが自分が絶対に決め、"
  },
  {
    "id": 73,
    "text": "選ぶって言ってたの、っていう風、、なんか少し落ち込んでいるという、"
  },
  {
    "id": 74,
    "text": "、さらにリーダーとしてみんなを導いていけるよう、、決心するシーンが本当に印象的で"
  },
  {
    "id": 75,
    "text": "、結構自分だったら楽観的、おやっ!"
  },
  {
    "id": 76,
    "text": "みたい、"
  },
  {
    "id": 77,
    "text": "思っちゃうタイプだ、、リーダーっていう、おしごこと、、"
  },
  {
    "id": 78,
    "text": "やったことがないからっていうのもあるんですけどそこを、"
  },
  {
    "id": 79,
    "text": "、何て言うん?"
  }
]