[
  {
    "id": 0,
    "text": "ぜひ端末準備してね、一緒に見ていきましょう。"
  },
  {
    "id": 1,
    "text": "ぜひ参加してくださいな。"
  },
  {
    "id": 2,
    "text": "よろしくお願いします。"
  },
  {
    "id": 3,
    "text": "さあそれでは早速今回のグロウグローリアスグロウのストーリーについてね、"
  },
  {
    "id": 4,
    "text": "振り返ろうと思うんですがまずね、最初にみんなと一緒に"
  },
  {
    "id": 5,
    "text": "見ていきたいだな。"
  },
  {
    "id": 6,
    "text": "1話だけね。"
  },
  {
    "id": 7,
    "text": "で"
  },
  {
    "id": 8,
    "text": "ま、割れると思うんです。"
  },
  {
    "id": 9,
    "text": "なんとなくね。"
  },
  {
    "id": 10,
    "text": "なんだけど、私はちょっと今回7話が見たいかななんて思ってるんですが、"
  },
  {
    "id": 11,
    "text": "みんなどうです?"
  },
  {
    "id": 12,
    "text": "ちょっとコメントでぜひ教えてください。"
  },
  {
    "id": 13,
    "text": "ああ、ね、もうすでに7って言ってくれてる。"
  },
  {
    "id": 14,
    "text": "みんな優しいね。"
  },
  {
    "id": 15,
    "text": "ありがとね。"
  },
  {
    "id": 16,
    "text": "あ、7がいいかな、7かな、7何しようかな、お言葉に合わせてね、"
  },
  {
    "id": 17,
    "text": "ありがとうございます。"
  },
  {
    "id": 18,
    "text": "じゃあみんなと一緒に7話見ていこうと思います。"
  },
  {
    "id": 19,
    "text": "どうぞ。"
  },
  {
    "id": 20,
    "text": "あ、私がやるんだった。"
  },
  {
    "id": 21,
    "text": "ごめんなさい。"
  },
  {
    "id": 22,
    "text": "どうすじゃないですね。"
  },
  {
    "id": 23,
    "text": "すいませ今からやりますね。"
  },
  {
    "id": 24,
    "text": "ええ。"
  },
  {
    "id": 25,
    "text": "負けませんから。"
  },
  {
    "id": 26,
    "text": "萩山ちゃんも本当いい子だよ、マジ。"
  },
  {
    "id": 27,
    "text": "。"
  },
  {
    "id": 28,
    "text": "ちゃんと、、、ここまででし。"
  },
  {
    "id": 29,
    "text": "、お互いを、ライバルとして認め合った瞬間だ、今。"
  }
