[
  {
    "id": 0,
    "text": "いろんな思いがあるじゃ。"
  },
  {
    "id": 1,
    "text": "なんかそういうので自分で自分を押しつぶしちゃいそうな時があるだけどでもそういう時になんかこの誰にも負け、"
  },
  {
    "id": 2,
    "text": "譲らないって気持ちがあればなんかもっと自分を自分として強くを持たせられるなって思った。"
  },
  {
    "id": 3,
    "text": "萩山ちゃん強いよマジ。"
  },
  {
    "id": 4,
    "text": "本当に。"
  },
  {
    "id": 5,
    "text": "なんか私も勉強になっちゃっ。"
  },
  {
    "id": 6,
    "text": "雫と一緒。"
  },
  {
    "id": 7,
    "text": "本当。"
  },
  {
    "id": 8,
    "text": "なんかあれだけね強い心を持っていたらなんか私からも羽が生えそうって思っちゃっ。"
  },
  {
    "id": 9,
    "text": "羽ばたいていき。"
  },
  {
    "id": 10,
    "text": "雫と一緒に私も頑張り。"
  },
  {
    "id": 11,
    "text": "どうぞよろしくお願いし。"
  },
  {
    "id": 12,
    "text": "っていう話でし。"
  },
  {
    "id": 13,
    "text": "勉強になっちゃう。"
  },
  {
    "id": 14,
    "text": "本当プロセカのストーリーは、マジで。"
  },
  {
    "id": 15,
    "text": "、勉強になるんだ、私。"
  },
  {
    "id": 16,
    "text": "私なんか心の支えになっ。"
  },
  {
    "id": 17,
    "text": "私も一緒になんか皆さんにもなんかこう、響いてたらすごく嬉しい。"
  },
  {
    "id": 18,
    "text": "。"
  },
  {
    "id": 19,
    "text": "、頑張りましよってみんな言ってくれ、。"
  },
  {
    "id": 20,
    "text": "みんな、一緒に。"
  },
  {
    "id": 21,
    "text": "お互い。"
  },
  {
    "id": 22,
    "text": "。"
  },
  {
