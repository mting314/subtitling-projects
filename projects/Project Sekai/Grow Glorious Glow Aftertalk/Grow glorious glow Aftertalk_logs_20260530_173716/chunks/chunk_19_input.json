[
  {
    "id": 0,
    "text": "足で左右違ったりして、、"
  },
  {
    "id": 1,
    "text": "、いわゆる絶対領域って言うんです、この。"
  },
  {
    "id": 2,
    "text": "ありがとうござい。"
  },
  {
    "id": 3,
    "text": "素敵、。"
  },
  {
    "id": 4,
    "text": "遥ちゃんもショートパンツ似合うから。"
  },
  {
    "id": 5,
    "text": "さすがでございます。"
  },
  {
    "id": 6,
    "text": "、、、、このイラスト。"
  },
  {
    "id": 7,
    "text": "これは、これ、特訓前。"
  },
  {
    "id": 8,
    "text": "遥、、"
  },
  {
    "id": 9,
    "text": "しずくのため、、栄養価が高く、低、低カロリーの食事、"
  },
  {
    "id": 10,
    "text": "作ってくれてるところです。"
  },
  {
    "id": 11,
    "text": "、本当、マジ。"
  },
  {
    "id": 12,
    "text": "遥ちゃんも、すごいストイックで食事制限頑張っ、くれてる子だ、"
  },
  {
    "id": 13,
    "text": "、、"
  },
  {
    "id": 14,
    "text": "のことももちろん詳しい、"
  },
  {
    "id": 15,
    "text": "なん、栄養価についてもすごい詳しいんだよ。"
  },
  {
    "id": 16,
    "text": "私も、、原稿を見ながら勉強、になるんだ。"
  },
  {
    "id": 17,
    "text": "。"
  },
  {
    "id": 18,
    "text": "これはちょっと脂質が高いよと、これ、、"
  },
  {
    "id": 19,
    "text": "なんだ、、糖質制限、糖質制限しても食べられるスイーツだよと。"
  },
  {
    "id": 20,
    "text": "、、なるほど、って私もちょっと、参考にさせてもらう時があるんだ、"
  },
  {
    "id": 21,
    "text": "、フィジカル、、食事はフィジカルの基本ですから。"
  },
  {
    "id": 22,
    "text": "体からです。"
  },
  {
    "id": 23,
    "text": "。"
  },
  {
    "id": 24,
    "text": "体作り。"
  },
  {
    "id": 25,
    "text": "こうやっ、遥ちゃん、"
  },
  {
    "id": 26,
    "text": "しずくを支えてくれてるん。"
  },
  {
    "id": 27,
    "text": "、ありがとうござい。"
  },
  {
    "id": 28,
    "text": "、色とりどりの、"
  },
  {
    "id": 29,
    "text": "いいです。"
  }
]