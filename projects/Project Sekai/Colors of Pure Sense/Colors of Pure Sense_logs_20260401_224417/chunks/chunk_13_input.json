[
  {
    "id": 0,
    "text": "絵奈 、絵に関するお話じゃなかったんですけど"
  },
  {
    "id": 1,
    "text": "、その1個前のあの私は雨っていう楽曲も歌わせていただいた"
  },
  {
    "id": 2,
    "text": "、あの 、絵奈のお絵お描きって言い方やだな"
  },
  {
    "id": 3,
    "text": "、あの 、絵のお話の時は"
  },
  {
    "id": 4,
    "text": "、あのなんかたまたま美術館に行ったんですよ"
  },
  {
    "id": 5,
    "text": "。"
  },
  {
    "id": 6,
    "text": "それで絵を見るっていうのは何かっていうのを自分もこう踏まえて演じることができて 、絵奈のことを知れて"
  },
  {
    "id": 7,
    "text": "、で 、今回はたまたま道をこう"
  },
  {
    "id": 8,
    "text": "、ふんふんふんって歩いてたら"
  },
  {
    "id": 9,
    "text": "、こう"
  },
  {
    "id": 10,
    "text": "、絵奈が通ってるみたいな 、その"
  },
  {
    "id": 11,
    "text": "、多分美術の道をを目指す人が通う学校が"
  },
  {
    "id": 12,
    "text": "、その 、道にあって"
  },
  {
    "id": 13,
    "text": "、あ 、こんな感じなんだ"
  },
  {
    "id": 14,
    "text": "、と思ってそこで傍から見るだけでも"
  },
  {
    "id": 15,
    "text": "、なんかすごい緊張感を感じてすごく厳しいところでやっているんだなっていうの改めて感じながらの収録をさせていただきました"
  },
  {
    "id": 16,
    "text": "。"
  },
  {
    "id": 17,
    "text": "なんかね 、こう"
  },
  {
    "id": 18,
    "text": "、ちょっとでも皆さんに絵奈のいる場所の質感だったりとかを伝えられたらなと思って日々演じております"
  },
  {
    "id": 19,
    "text": "。"
  },
  {
    "id": 20,
    "text": "ありがとうございます"
  },
  {
    "id": 21,
    "text": "。 はい"
  },
  {
    "id": 22,
    "text": "、ということでしてえまだあと数十秒ある"
  },
  {
    "id": 23,
    "text": "。"
  },
  {
    "id": 24,
    "text": "そろそろね 、人によってはアフターライブも見ていただけたところですかね"
  },
  {
    "id": 25,
    "text": "。"
  },
  {
    "id": 26,
    "text": "やっぱりストーリー後の内容になっているのであの 、絵奈の清々しいお顔というか"
  },
  {
    "id": 27,
    "text": "、まだでもこれからが大変なんですけれども"
  },
  {
    "id": 28,
    "text": "、ちゃんと覚悟を決められた絵奈の"
  },
  {
    "id": 29,
    "text": "、あの"
  },
  {
    "id": 30,
    "text": "、表情だったりとか"
  },
  {
    "id": 31,
    "text": "、あの"
  },
  {
    "id": 32,
    "text": "、歌声だったりとかが今絶賛届いている最中だったら嬉しいなと思っております"
  },
  {
    "id": 33,
    "text": "。"
  },
  {
    "id": 34,
    "text": "はい 。"
  },
  {
    "id": 35,
    "text": "ね 。"
  },
  {
    "id": 36,
    "text": "いや 、いいストーリーですよ"
  },
  {
