  {
    "id": 1,
    "text": "そんな安心感と"
  },
  {
    "id": 2,
    "text": "、"
  },
  {
    "id": 3,
    "text": "でも 、これからあるんだっていう"
  },
  {
    "id": 4,
    "text": "、"
  },
  {
    "id": 5,
    "text": "なんか 、"
  },
  {
    "id": 6,
    "text": "いろんな気持ちを込めて 、だけど"
  },
  {
    "id": 7,
    "text": "、なんかこう"
  },
  {
    "id": 8,
    "text": "、"
  },
  {
    "id": 9,
    "text": "ほっとしてるエナもいて 、みたいなのを"
  },
  {
    "id": 10,
    "text": "、"
  },
  {
    "id": 11,
    "text": "すごい 、"
  },
  {
    "id": 12,
    "text": "最後の方は"
  },
  {
    "id": 13,
    "text": "、"
  },
  {
    "id": 14,
    "text": "思いながら"
  },
  {
    "id": 15,
    "text": "、"
  },
  {
    "id": 16,
    "text": "演じていて"
  },
  {
    "id": 17,
    "text": "、"
  },
  {
    "id": 18,
    "text": "で 、そのなんで7話8話を"
  },
  {
    "id": 19,
    "text": "、"
  },
  {
    "id": 20,
    "text": "選んだかっていうと 、そのお父さんのことをやっぱり"
  },
  {
    "id": 21,
    "text": "、いろいろあったし"
  },
  {
    "id": 22,
    "text": "、"
  },
  {
    "id": 23,
    "text": "向き合えない時期もあったけど"
  },
  {
    "id": 24,
    "text": "、"
  },
  {
    "id": 25,
    "text": "すごく 、"
  },
  {
    "id": 26,
    "text": "憧れているのは 、多分"
  },
  {
    "id": 27,
    "text": "、思春期が来て 、いろんな出来事があって"
  },
  {
    "id": 28,
    "text": "、お父さんもやっぱ言葉選びが上手じゃない部分があって"
  },
  {
    "id": 29,
    "text": "、いつの間にか"
  },
  {
    "id": 30,
    "text": "、"
  },
  {
    "id": 31,
    "text": "自分の中で 、悔しくて隠していたお父さんを尊敬する気持ちっていうのは"
  },
  {
    "id": 32,
    "text": "、"
  },
  {
    "id": 33,
    "text": "エナが 、画家として一歩成長したことによって"
  },
  {
    "id": 34,
    "text": "、"
  },
  {
    "id": 35,
    "text": "やっぱりあるんだなっていうのを思い出して"
  },
  {
    "id": 36,
    "text": "、"
  },
  {
    "id": 37,
    "text": "だからこそ 、幼少期のエナも"
  },
  {
    "id": 38,
    "text": "、演じさせていただいたんですけど"
  },
  {
    "id": 39,
    "text": "、"
  },
  {
    "id": 40,
    "text": "もう子供だから純粋だし"
  },
  {
    "id": 41,
    "text": "、"
  },
  {
    "id": 42,
    "text": "もう全部見えるものが新しくってキラキラ輝いてて"
  },
  {
    "id": 43,
    "text": "、"
  },
  {
    "id": 44,
    "text": "そんな世界の中に 、お父さんがいて"
  },
  {
    "id": 45,
    "text": "、そのお父さんが"
  },
  {
    "id": 46,
    "text": "、"
  },
  {
    "id": 47,
    "text": "もっともっとエナにとってすごい人っていう"
  },
  {
    "id": 48,
    "text": "、"
  },
  {
    "id": 49,
    "text": "憧れの人 、すごいものを生み出す人っていう"
  },
  {
    "id": 50,
    "text": "、もう"
  },
  {
    "id": 51,
    "text": "、"
  },
  {
    "id": 52,
    "text": "光の塊みたいな"
  },
  {
    "id": 53,
    "text": "、"
  },
  {
    "id": 54,
    "text": "そういう対象の方と喋ってるっていうイメージだったり"
  },
  {
    "id": 55,
    "text": "、とか、そんなお父さんが生み出す絵の"
  },
  {
    "id": 56,
    "text": "凄さみたいなのを全部頭の中で感じながらお芝居をしたからこそそのキラキラを保ったままあの"
  },
  {
    "id": 57,
    "text": "、絵を描いてるシーンに戻ってあの"
  },
  {
    "id": 58,
    "text": "、あんま区切らずに演じられ"
  },
  {
    "id": 59,
    "text": "、演じさせてもらったのでそのキラキラとお父さんと一緒に見た景色を抱きしめたまま楽しく絵を描くっていうシーンに行けたのが個人的にはすごく"
  },
  {
    "id": 60,
    "text": "でかくてで 、初めて楽しいってちゃんと言えたそれがすごく多分絵奈にとってもやっとたどり着いた道の途中ではあるけど"
  },
  {
    "id": 61,
    "text": "、やっとここに来れたっていうああ"
  },
  {
    "id": 62,
    "text": "、泣きそうっていうのもあるからああ"
  },
  {
    "id": 63,
    "text": "、やばいはい"
  },
  {
    "id": 64,
    "text": "。"
  },
  {
    "id": 65,
    "text": "あの本当台本見た時にめっちゃ泣いちゃったんですよ 、家で"
  },
  {
    "id": 66,
    "text": "。 もう良かったね"
  },
  {
    "id": 67,
    "text": "、と思って"
  },
  {
    "id": 68,
    "text": "。"
  },
  {
    "id": 69,
    "text": "うわあ 。"
  },
  {
    "id": 70,
    "text": "放送事故"
  },
  {
    "id": 71,
    "text": "。"
  },
  {
    "id": 72,
    "text": "あの"
  },
  {
    "id": 73,
    "text": "ね 、5年間"
  },
  {
    "id": 74,
    "text": "、ま 、絵奈の時空の中で5年じゃないですけど本当にいろんな思いがあると思うし"
  },
  {
    "id": 75,
    "text": "、皆さんも結構絵奈のストーリーって共感しやすいと思うんですけど私もやっぱり芸術っていうあの正解のないあの"
  },
  {
    "id": 76,
    "text": "、世界にいるからこそすごく気持ちが分かるの"
  },
  {
    "id": 77,
    "text": "。"
  },
  {
    "id": 78,
    "text": "でもそれだけじゃなくて絵奈が頑張ってきたなんか"
  },
  {
    "id": 79,
    "text": "ものがちょっとこう報われるというか 、報われるって言ったら簡単なんですけど"
